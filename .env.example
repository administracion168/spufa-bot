# ── Required ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
OXAPAY_MERCHANT_KEY=your_oxapay_merchant_key_here

# ── Bot identity ───────────────────────────────────────────────────────────────
# Username of your bot WITHOUT the @ (e.g. spufa_bot)
BOT_USERNAME=spufa_bot

# ── Admin ──────────────────────────────────────────────────────────────────────
# Your personal Telegram user_id — message @userinfobot to find it
ADMIN_TELEGRAM_ID=123456789

# ── OxaPay (optional but recommended) ─────────────────────────────────────────
# Webhook HMAC secret — set this in OxaPay dashboard → Merchant → Settings
OXAPAY_WEBHOOK_SECRET=your_webhook_secret_here
# Payout API key — needed to send referral withdrawals automatically
OXAPAY_PAYOUT_KEY=your_oxapay_payout_key_here

# ── Public webhook URL ─────────────────────────────────────────────────────────
# Set this to your Railway public URL so OxaPay can reach the webhook
# Example: https://spufa.up.railway.app
WEBHOOK_BASE_URL=https://your-app.up.railway.app

# ── Data persistence (Railway Volume) ─────────────────────────────────────────
# On Railway: add a Volume mounted at /data, then set DATA_DIR=/data
# Locally: leave unset (defaults to the project folder)
DATA_DIR=/data

# ── Railway sets this automatically — DO NOT set manually on Railway ──────────
# PORT=8080

# ── Optional local override ───────────────────────────────────────────────────
# WEBHOOK_PORT=5001
